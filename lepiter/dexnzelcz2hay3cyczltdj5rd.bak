					"uidString" : "zwC8B6TOQTCQn8ldLycIGA=="
				},
				"code" : "person := Person identifiedBy: PartyId new.\n\n    person\n        recordFactNamed: #name\n        value: 'Alice'.\n\n    self\n        assert:\n            (person factNamed: #name)\n        equals: 'Alice'."
			}
